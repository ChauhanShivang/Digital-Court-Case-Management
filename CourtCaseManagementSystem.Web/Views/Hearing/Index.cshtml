                <th>Case No</th>
                <th>Case Title</th>
                <th>Court</th>
                <th>Hearing Date</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td>CC-2026-215</td>
                <td>Patel vs Sharma</td>
