@{
    ViewData["Title"] = "Reports & Analytics";
}

<h1 class="h3 mb-4 text-gray-800">Reports & Analytics</h1>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-left-primary shadow py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                    Total Cases (This Year)
                </div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">1,250</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header">
        <h6 class="m-0 font-weight-bold text-primary">Case Distribution by Court</h6>
    </div>
    <div class="card-body">
        <table class="table table-bordered">
            <thead>
            <tr>
                <th>Court</th>
                <th>Total Cases</th>
                <th>Pending</th>
                <th>Closed</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <td>Surat District Court</td>
                <td>520</td>
                <td>140</td>
                <td>380</td>
            </tr>
            <tr>
                <td>Ahmedabad District Court</td>
                <td>430</td>
                <td>120</td>
                <td>310</td>
            </tr>
            <tr>
                <td>Gujarat High Court</td>
                <td>300</td>
                <td>80</td>
                <td>220</td>
            </tr>
            </tbody>
        </table>
    </div>
</div>