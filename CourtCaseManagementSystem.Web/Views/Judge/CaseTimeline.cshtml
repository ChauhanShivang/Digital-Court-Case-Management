@model List<CourtCaseManagementSystem.Core.Entities.CaseEvent>

<h2>Case Timeline</h2>

<ul class="timeline">

    @foreach (var e in Model)
    {
        <li class="mb-3">
            <strong>@e.EventType</strong><br/>
            @e.Description<br/>
            <small class="text-muted">
                @e.EventDate.ToString("dd MMM yyyy HH:mm")
            </small>
        </li>
    }

</ul>