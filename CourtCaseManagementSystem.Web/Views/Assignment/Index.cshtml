@{
    ViewData["Title"] = "Assign Judge";
}

<h1 class="h3 mb-4 text-gray-800">Assign Judge to Case</h1>

<div class="card shadow mb-4">
    <div class="card-body">

        <form method="post" asp-action="Assign">
            <div class="form-group">
                <label>Select Case</label>
                <select name="caseId" class="form-control">
                    @foreach (var c in ViewBag.Cases)
                    {
                        <option value="@c.Id">
                            @c.CaseNumber - @c.Title
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Select Judge</label>
                <select name="judgeId" class="form-control">
                    @foreach (var j in ViewBag.Judges)
                    {
                        <option value="@j.Id">
                            @j.FullName
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>First Hearing Date</label>
                <input type="date" class="form-control" />
            </div>

            <button class="btn btn-primary">Assign Judge</button>
        </form>

    </div>
</div>