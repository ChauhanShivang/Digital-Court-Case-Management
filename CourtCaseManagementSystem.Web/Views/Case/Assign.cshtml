@{
    var caseData = ViewBag.Case;
}

<h2>Assign Judge</h2>

<form method="post">
    <input type="hidden" name="caseId" value="@caseData.Id" />

    <div class="form-group">
        <label>Case</label>
        <input class="form-control" value="@caseData.CaseNumber - @caseData.Title" disabled />
    </div>

    <div class="form-group mt-3">
        <label>Select Judge</label>
        <select name="judgeId" class="form-control">
            @foreach (var judge in ViewBag.Judges)
            {
                <option value="@judge.Id">@judge.FullName</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary mt-4">
        Assign
    </button>
</form>