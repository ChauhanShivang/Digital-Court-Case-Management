@model List<CourtCaseManagementSystem.Core.Entities.Case>

<h1 class="h3 mb-4 text-gray-800">My Cases</h1>

<div class="card shadow mb-4">
    <div class="card-body table-responsive">
        <table class="table table-bordered">
            <thead>
            <tr>
                <th>Case No</th>
                <th>Case Type</th>
                <th>Title</th>
                <th>Court</th>
                <th>Lawyer</th>
                <th>Status</th>
                @if (Context.Session.GetString("UserRole") == "Clerk")
                {
                    <th>Action</th>
                }
            </tr>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>
                        <a asp-controller="Case"
                           asp-action="Details"
                           asp-route-id="@c.Id"
                           class="font-weight-bold text-primary">
                            @c.CaseNumber
                        </a>
                    </td>
                    <td>@c.CaseType</td>
                    <td>@c.Title</td>
                    <td>@c.Court?.Name</td>
                    <td>@c.Lawyer?.FullName</td>
                    <td>
                        @if (c.Status == "Registered")
                        {
                            <span class="badge badge-info">Registered</span>
                        }
                        else if (c.Status == "Active")
                        {
                            <span class="badge badge-warning">Active</span>
                        }
                        else if (c.Status == "Closed")
                        {
                            <span class="badge badge-success">Closed</span>
                        }
                    </td>
                    @if (Context.Session.GetString("UserRole") == "Clerk")
                    {
                        <td>
                            <a asp-action="Assign"
                               asp-route-id="@c.Id"
                               class="btn btn-sm btn-outline-primary">
                                Assign Judge
                            </a>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>