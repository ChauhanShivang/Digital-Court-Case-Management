@model CourtCaseManagementSystem.Core.Entities.Case

@{
    ViewData["Title"] = "Register Case";
}

<h2 class="mb-4">Register New Case</h2>

<form method="post">

    <div class="form-group">
        <label>Case Number</label>
        <input asp-for="CaseNumber" class="form-control" required />
    </div>

    <div class="form-group mt-3">
        <label>Title</label>
        <input asp-for="Title" class="form-control" required />
    </div>

    <div class="form-group mt-3">
        <label>Case Type</label>
        <select asp-for="CaseType" class="form-control">
            <option value="Civil">Civil</option>
            <option value="Criminal">Criminal</option>
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group mt-3">
        <label>Court</label>
        <select asp-for="CourtId" class="form-control">
            @foreach (var court in ViewBag.Courts)
            {
                <option value="@court.Id">@court.Name</option>
            }
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Assign Lawyer</label>
        <select asp-for="LawyerId" class="form-control">
            @foreach (var lawyer in ViewBag.Lawyers)
            {
                <option value="@lawyer.Id">@lawyer.FullName</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary mt-4">
        Register Case
    </button>
</form>