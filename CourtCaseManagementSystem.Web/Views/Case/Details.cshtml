@model CourtCaseManagementSystem.Core.Entities.Case
@{
    ViewData["Title"] = "Case Details";
}

<h1 class="h3 mb-4 text-gray-800">Case Details</h1>

<div class="card shadow mb-4">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" id="caseTabs" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" id="overview-tab" data-toggle="tab" href="#overview" role="tab">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="hearings-tab" data-toggle="tab" href="#hearings" role="tab">Hearings</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="documents-tab" data-toggle="tab" href="#documents" role="tab">Documents</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="judgment-tab" data-toggle="tab" href="#judgment" role="tab">Judgment</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" id="timeline-tab" data-toggle="tab" href="#timeline" role="tab">Timeline</a>
            </li>
        </ul>
    </div>

    <div class="card-body">
        <div class="tab-content" id="caseTabContent">

            <!-- Overview Tab -->
            <div class="tab-pane fade show active" id="overview" role="tabpanel">
                <p><strong>Case No:</strong> @Model.CaseNumber</p>
                <p><strong>Title:</strong> @Model.Title</p>
                <p><strong>Case Type:</strong> @Model.CaseType</p>
                <p><strong>Court:</strong> @Model.Court?.Name</p>
                <p><strong>Lawyer:</strong> @Model.Lawyer?.FullName</p>

                <p>
                    <strong>Status:</strong>

                    @if (Model.Status == "Registered")
                    {
                        <span class="badge badge-info">Registered</span>
                    }
                    else if (Model.Status == "Active")
                    {
                        <span class="badge badge-warning">Active</span>
                    }
                    else if (Model.Status == "Closed")
                    {
                        <span class="badge badge-success">Closed</span>
                    }

                </p>
            </div>

            <!-- Hearings Tab -->
            <div class="tab-pane fade" id="hearings" role="tabpanel">
                <table class="table table-bordered">
                    <thead>
                    <tr>
                        <th>Hearing Date</th>
                        <th>Status</th>
                        <th>Notes</th>
                    </tr>
                    </thead>
                    <tbody>

                    @if (Model.Hearings != null && Model.Hearings.Any())
                    {
                        foreach (var h in Model.Hearings)
                        {
                            <tr>
                                <td>@h.HearingDate.ToString("dd MMM yyyy")</td>
                                <td>@h.Status</td>
                                <td>@h.Remarks</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">
                                No hearings scheduled
                            </td>
                        </tr>
                    }

                    </tbody>
                </table>
            </div>

            <!-- Documents Tab -->
            <div class="tab-pane fade" id="documents" role="tabpanel">
                <!-- Upload Form -->
                <form asp-controller="Document"
                      asp-action="Upload"
                      method="post"
                      enctype="multipart/form-data"
                      class="mb-3">

                    <input type="hidden" name="caseId" value="@Model.Id"/>

                    <div class="form-group">
                        <label>Document Type</label>
                        <select name="documentType" class="form-control">
                            <option>Evidence</option>
                            <option>Affidavit</option>
                            <option>Petition</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="form-group mt-2">
                        <input type="file" name="file" class="form-control"/>
                    </div>

                    <button class="btn btn-primary mt-2">
                        Upload Document
                    </button>

                </form>


                <!-- Documents Table -->

                <table class="table table-bordered">
                    <thead>
                    <tr>
                        <th>Document</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Download</th>
                    </tr>
                    </thead>

                    <tbody>

                    @if (Model.Documents != null && Model.Documents.Any())
                    {
                        foreach (var doc in Model.Documents)
                        {
                            <tr>
                                <td>@doc.FileName</td>
                                <td>@doc.DocumentType</td>
                                <td>@doc.UploadedAt.ToString("dd MMM yyyy")</td>

                                <td>
                                    <a asp-controller="Document"
                                       asp-action="Download"
                                       asp-route-id="@doc.Id"
                                       class="btn btn-outline-primary btn-sm">

                                        Download
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">
                                No documents uploaded yet
                            </td>
                        </tr>
                    }

                    </tbody>

                </table>
            </div>

            <!-- Judgment Tab -->
            <div class="tab-pane fade" id="judgment" role="tabpanel">
                @if (Model.Judgment != null)
                {
                    <p><strong>Status:</strong> @Model.Judgment.Status</p>
                    <p>@Model.Judgment.Content</p>
                }
                else
                {
                    <p>No judgment uploaded yet.</p>
                }
            </div>
            
            <div class="tab-pane fade" id="timeline" role="tabpanel">
                <ul class="timeline">

                    @if (Model.CaseEvents != null && Model.CaseEvents.Any())
                    {
                        foreach (var e in Model.CaseEvents.OrderByDescending(e => e.EventDate))
                        {
                            <li>
                                <span class="text-primary font-weight-bold">
                                    @e.EventDate.ToString("dd MMM yyyy")
                                </span>

                                <p>@e.EventType</p>
                                <small>@e.Description</small>
                            </li>
                        }
                    }
                    else
                    {
                        <li>No timeline events yet</li>
                    }

                </ul>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="hearingModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Hearing Details</h5>
                <button class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <p><strong>Judge:</strong> Hon. Justice A. Shah</p>
                <p><strong>Court:</strong> Surat District Court</p>
                <p><strong>Status:</strong> Scheduled</p>
                <p><strong>Remarks:</strong> Final arguments</p>
            </div>
        </div>
    </div>
</div>